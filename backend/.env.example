# Environment

NODE_ENV=development
PORT=5001

# Frontend URL (for CORS)

FRONTEND_URL=http://localhost:5173

# Database

MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<database>

# JWT Authentication

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=1h

JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRE=7d

# Superadmin Configuration (Initial Seed User)

SUPERADMIN_NAME=Admin Name
SUPERADMIN_USERNAME=admin_username
SUPERADMIN_EMAIL=[admin@example.com](mailto:admin@example.com)
SUPERADMIN_PASSWORD=strong_password_here
